# Base URL of the Django API (no trailing slash).
# Local dev (Vite proxy to Django on :8000): leave empty so requests hit "/api/..." on the dev server.
#   VITE_API_BASE_URL=
#
# Direct API (no proxy): set the Django base URL explicitly.
#   VITE_API_BASE_URL=http://localhost:8000
#
# Split deploy (frontend on Vercel, backend elsewhere like Render):
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000
