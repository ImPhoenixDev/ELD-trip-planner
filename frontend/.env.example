# Base URL of the Django API (no trailing slash).
# Local dev default is http://localhost:8000
#
# Same-origin deploys (e.g. Vercel Services, where the backend is mounted at /api
# on the same domain): set this to an EMPTY value so requests go to "/api/..."
# on the current origin:
#   VITE_API_BASE_URL=
#
# Split deploy (frontend on Vercel, backend elsewhere like Render):
#   VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=http://localhost:8000
