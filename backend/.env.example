# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS (comma-separated frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Routing / geocoding ---
# Optional but recommended for accurate truck routing.
# Get a free key at https://openrouteservice.org/dev/#/signup
# Without a key the app falls back to keyless OpenStreetMap services.
ORS_API_KEY=

# Average driving speed (mph) used for the great-circle fallback only.
AVERAGE_SPEED_MPH=55
